{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": false,
    "composite": true,
    "noUncheckedIndexedAccess": false
  },
  "exclude": ["node_modules", "dist", ".turbo", "**/*.test.ts", "**/*.test.tsx"]
}
